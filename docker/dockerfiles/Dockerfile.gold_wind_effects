FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.lock pyproject.toml README.md ./

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.lock

COPY gold_wind_effects/ gold_wind_effects/
COPY docker/entrypoints/entrypoint_gold_wind_effects.sh /entrypoint_gold_wind_effects.sh

RUN chmod +x /entrypoint_gold_wind_effects.sh \
    && pip install --no-cache-dir --no-deps .

ENTRYPOINT ["/entrypoint_gold_wind_effects.sh"]
CMD ["--help"]