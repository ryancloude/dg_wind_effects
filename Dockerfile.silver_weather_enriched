FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.lock pyproject.toml README.md ./

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.lock

COPY silver_weather_enriched/ silver_weather_enriched/
COPY docker/entrypoint_silver_weather_enriched.sh /entrypoint_silver_weather_enriched.sh

RUN chmod +x /entrypoint_silver_weather_enriched.sh \
    && pip install --no-cache-dir --no-deps .

ENTRYPOINT ["/entrypoint_silver_weather_enriched.sh"]
CMD ["--help"]